  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs", // Base default, can be overridden
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
